{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@obsidianhub/core": ["packages/core/src/index.ts"],
      "@obsidianhub/vault": ["packages/vault/src/index.ts"],
      "@obsidianhub/sync": ["packages/sync/src/index.ts"],
      "@obsidianhub/git": ["packages/git/src/index.ts"],
      "@obsidianhub/search": ["packages/search/src/index.ts"],
      "@obsidianhub/config": ["packages/config/src/index.ts"],
      "@obsidianhub/actions": ["packages/actions/src/index.ts"]
    }
  }
}
