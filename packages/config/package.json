{
  "name": "@obsidianhub/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "corepack pnpm --filter @obsidianhub/core build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "corepack pnpm --filter @obsidianhub/core build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@obsidianhub/core": "workspace:*"
  }
}
